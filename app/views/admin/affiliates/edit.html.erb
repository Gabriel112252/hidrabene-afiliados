<div class="mb-6 flex items-center gap-3">
  <%= link_to "← Voltar", admin_affiliate_path(@affiliate), class: "text-sm text-[#d1477a] hover:opacity-75" %>
</div>

<div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6">
  <h1 class="text-lg font-extrabold text-[#d1477a] mb-6">Editar · <%= @affiliate.name %></h1>

  <% if @affiliate.errors.any? %>
    <div class="mb-4 rounded-xl bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">
      <ul class="list-disc list-inside space-y-1">
        <% @affiliate.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= form_with model: [:admin, @affiliate], local: true, class: "space-y-5" do |f| %>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div>
        <%= f.label :name, "Nome completo", class: "block text-xs font-semibold uppercase tracking-wide text-gray-500 mb-1" %>
        <%= f.text_field :name, class: "w-full rounded-xl border border-gray-200 px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-[#d1477a]" %>
      </div>
      <div>
        <%= f.label :cpf, "CPF", class: "block text-xs font-semibold uppercase tracking-wide text-gray-500 mb-1" %>
        <%= f.text_field :cpf, class: "w-full rounded-xl border border-gray-200 px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-[#d1477a]" %>
      </div>
      <div>
        <%= f.label :email, "E-mail", class: "block text-xs font-semibold uppercase tracking-wide text-gray-500 mb-1" %>
        <%= f.email_field :email, class: "w-full rounded-xl border border-gray-200 px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-[#d1477a]" %>
      </div>
      <div>
        <%= f.label :whatsapp, "WhatsApp", class: "block text-xs font-semibold uppercase tracking-wide text-gray-500 mb-1" %>
        <%= f.text_field :whatsapp, class: "w-full rounded-xl border border-gray-200 px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-[#d1477a]" %>
      </div>
      <div>
        <%= f.label :tiktok, "TikTok", class: "block text-xs font-semibold uppercase tracking-wide text-gray-500 mb-1" %>
        <%= f.text_field :tiktok, class: "w-full rounded-xl border border-gray-200 px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-[#d1477a]" %>
      </div>
      <div>
        <%= f.label :cep, "CEP", class: "block text-xs font-semibold uppercase tracking-wide text-gray-500 mb-1" %>
        <%= f.text_field :cep, class: "w-full rounded-xl border border-gray-200 px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-[#d1477a]" %>
      </div>
      <div class="md:col-span-2">
        <%= f.label :street, "Rua", class: "block text-xs font-semibold uppercase tracking-wide text-gray-500 mb-1" %>
        <%= f.text_field :street, class: "w-full rounded-xl border border-gray-200 px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-[#d1477a]" %>
      </div>
      <div>
        <%= f.label :number, "Número", class: "block text-xs font-semibold uppercase tracking-wide text-gray-500 mb-1" %>
        <%= f.text_field :number, class: "w-full rounded-xl border border-gray-200 px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-[#d1477a]" %>
      </div>
      <div>
        <%= f.label :complement, "Complemento", class: "block text-xs font-semibold uppercase tracking-wide text-gray-500 mb-1" %>
        <%= f.text_field :complement, class: "w-full rounded-xl border border-gray-200 px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-[#d1477a]" %>
      </div>
      <div>
        <%= f.label :neighborhood, "Bairro", class: "block text-xs font-semibold uppercase tracking-wide text-gray-500 mb-1" %>
        <%= f.text_field :neighborhood, class: "w-full rounded-xl border border-gray-200 px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-[#d1477a]" %>
      </div>
      <div>
        <%= f.label :city, "Cidade", class: "block text-xs font-semibold uppercase tracking-wide text-gray-500 mb-1" %>
        <%= f.text_field :city, class: "w-full rounded-xl border border-gray-200 px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-[#d1477a]" %>
      </div>
      <div>
        <%= f.label :state, "Estado", class: "block text-xs font-semibold uppercase tracking-wide text-gray-500 mb-1" %>
        <%= f.text_field :state, class: "w-full rounded-xl border border-gray-200 px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-[#d1477a]" %>
      </div>
    </div>

    <div class="flex items-center gap-3 pt-2">
      <%= f.submit "Salvar alterações",
        class: "rounded-xl bg-[#d1477a] px-6 py-2.5 text-sm font-semibold text-white shadow hover:bg-[#c03d6e] transition-colors cursor-pointer" %>
      <%= link_to "Cancelar", admin_affiliate_path(@affiliate),
        class: "text-sm text-gray-500 hover:text-gray-700" %>
    </div>
  <% end %>
</div>
