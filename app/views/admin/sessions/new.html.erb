<div class="min-h-[80vh] flex items-center justify-center">
  <div class="w-full max-w-sm">
    <div class="mb-8 text-center">
      <h1 class="text-2xl font-extrabold text-[#d1477a]">Admin</h1>
      <p class="mt-1 text-sm text-gray-500">Acesso restrito</p>
    </div>

    <%= form_with url: admin_login_path, local: true, class: "space-y-4" do |f| %>
      <div>
        <%= label_tag :email, "E-mail", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= email_field_tag :email, nil, autofocus: true,
          class: "w-full rounded-xl border border-gray-200 px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-[#d1477a]" %>
      </div>

      <div>
        <%= label_tag :password, "Senha", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= password_field_tag :password, nil,
          class: "w-full rounded-xl border border-gray-200 px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-[#d1477a]" %>
      </div>

      <%= submit_tag "Entrar",
        class: "w-full rounded-xl bg-[#d1477a] px-4 py-3 text-sm font-semibold text-white shadow hover:bg-[#c03d6e] transition-colors cursor-pointer" %>
    <% end %>
  </div>
</div>
